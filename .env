# ============================================================
#  mall-admin-web 后台管理前端 — 默认/开发环境配置
#
#  【环境变量优先级】
#  Vite 的环境变量加载顺序：
#  1. .env                — 所有环境通用
#  2. .env.development    — 开发环境专用（npm run dev）
#  3. .env.production     — 生产环境专用（npm run build）
#
#  同名变量后加载的会覆盖先加载的。
#  所以 .env.development 中的 VITE_BASE_SERVER_URL 会覆盖 .env 中的值。
#
#  【本地开发说明】
#  本地开发时后端跑在 localhost:8080（mall-admin 直连，不经过 Gateway）。
#  部署到生产环境后改为相对路径 /mall-admin（经过 Nginx → Gateway）。
# ============================================================

# 后端 API 基础路径（本地开发时直连 mall-admin 后端）
# 注意：本地开发不经过 Gateway，直接连 mall-admin 的 8080 端口
VITE_BASE_SERVER_URL = http://localhost:8080

# 是否使用 OSS 对象存储（本地开发关闭，使用 Minio 或本地存储）
VITE_USE_OSS = false

# OSS 上传路径（阿里云 OSS 地址）
VITE_OSS_UPLOAD_URL = http://macro-oss.oss-cn-shenzhen.aliyuncs.com

# Minio 上传相对路径（本地对象存储）
VITE_MINIO_UPLOAD_URL = /minio/upload
